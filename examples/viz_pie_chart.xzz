// x1zzLang Visualization Example — Pie Chart
// 예산 카테고리별 분포를 파이 차트로 시각화

type BudgetData = {
    category: string,
    amount: float,
}

v by_category = load("budget.csv") :: BudgetData
    |> groupBy("category")
    |> sum("amount")
    |> chart {
        type: pie
        label: category
        value: amount
        title: "예산 분포"
    };
