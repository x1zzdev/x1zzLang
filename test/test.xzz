type AirQuality = {
    date: string,
    station: string,
    pm10: Option<float>,
    pm25: Option<float>,
};

type StationInfo = {
    station: string,
    district: string,
    population: int,
};

// 1. air 데이터 — replace로 문자열 정제 후 fillNull
v air = load("examples/seoul_air_2026.csv") :: AirQuality
    |> fillNull("pm10", 0.0)
    |> fillNull("pm25", 0.0);

// 2. stations 데이터 — rename으로 컬럼명 통일
v stations = load("test/seoul_station_info.csv") :: StationInfo
    |> rename("district", "region")
    |> select([station, region, population]);

// 3. pm ratio 계산 (air만)
v air_with_ratio = air
    |> filter(col("pm10") > 0)
    |> filter(col("pm25") > 0)
    |> withColumn(
        "pm_ratio",
        col("pm25") / col("pm10")
    );

// 4. station별 평균 pm25
v station_pm25 = air_with_ratio
    |> filter(col("station") != "평균")
    |> groupBy("station")
    |> mean("pm25");

// 5. join — left_on/right_on으로 다른 키명 연결
v enriched = station_pm25
    |> join(stations, left_on: "station", right_on: "station");

// 6. 인구 대비 지표
v final_result = enriched
    |> withColumn(
        "pm25_per_1000",
        col("pm25") / col("population") * 1000
    )
    |> orderBy("pm25_per_1000", desc: true)
    |> take(10);

// 7. chart
final_result
    |> chart({
        type: "bar",
        x: "region",
        y: "pm25_per_1000",
        title: "인구 대비 PM2.5 농도 상위 10개 지역"
    });
